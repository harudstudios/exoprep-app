<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="16dp"
    android:paddingBottom="16dp"
    android:paddingEnd="16dp">

    <!-- Project Name Title -->
    <TextView
        android:id="@+id/notification_project_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_marginBottom="12dp"
        android:text="Focus Session"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary" />

    <!-- Play/Pause Button with FrameLayout to ensure circular shape -->
    <FrameLayout
        android:id="@+id/notification_button_container"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_below="@id/notification_project_name"
        android:layout_alignParentStart="true">
        
        <ImageButton
            android:id="@+id/notification_play_pause_button"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/notification_button_background"
            android:src="@drawable/ic_pause"
            android:scaleType="centerInside"
            android:padding="16dp" 
            android:textStyle="bold" />
    </FrameLayout>

    <!-- Timer Text -->
    <TextView
        android:id="@+id/notification_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/notification_project_name"
        android:layout_toEndOf="@id/notification_button_container"
        android:layout_marginStart="16dp"
        android:layout_centerVertical="true"
        android:text="00:04"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:textColor="?android:attr/textColorPrimary" />

    <!-- Remaining Time -->
    <TextView
        android:id="@+id/notification_remaining_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/notification_project_name"
        android:layout_alignParentEnd="true"
        android:layout_alignBottom="@id/notification_timer"
        android:text="- 24:56"
        android:textSize="14sp"
        android:textColor="?android:attr/textColorSecondary" />

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/notification_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_below="@id/notification_button_container"
        android:layout_marginTop="16dp"
        android:progressDrawable="@drawable/progress_bar_rounded"
        android:progress="10"
        android:max="100" />

</RelativeLayout>
